{
  "builds": [
    {
      "src": "main/**",
      "use": "@vercel/static"
    },
    {
      "src": "login/**",
      "use": "@vercel/static"
    },
    {
      "src": "images/**",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/main/main.html"
    },
    {
      "src": "/login",
      "dest": "/login/login.html"
    },
    {
      "src": "/signup",
      "dest": "/login/signup.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}